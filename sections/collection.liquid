{% comment %}
  This section is used in the collection template to render collection page
  listing all products within a collection.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/collection
{% endcomment %}

<section class="collection-page full-width">
  <div class="collection-page__container">
    <h1 class="collection-page__title">{{ collection.title }}</h1>
    {% if collection.description != blank %}
      <p class="collection-page__desc">{{ collection.description }}</p>
    {% endif %}

    <div class="collection-page__grid">
      {% paginate collection.products by 20 %}
        {% for product in collection.products %}
          <a href="{{ product.url }}" class="product-card">
            <div class="product-card__image">
              {% if product.featured_image %}
                {% render 'image', class: 'product-card__img', image: product.featured_image %}
              {% endif %}
            </div>
            <div class="product-card__info">
              <h3 class="product-card__name">{{ product.title | escape }}</h3>
              <p class="product-card__price">{{ product.price | money }}</p>
            </div>
          </a>
        {% endfor %}

        {% if paginate.pages > 1 %}
          <div class="collection-page__pagination">
            {{ paginate | default_pagination }}
          </div>
        {% endif %}
      {% endpaginate %}
    </div>
  </div>
</section>

{% stylesheet %}
  .collection-page {
    background-color: var(--color-brand-bg, #0d0d0d);
    color: var(--color-brand-fg, #f5f0e8);
  }

  .collection-page__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .collection-page__title {
    font-family: var(--font-heading, "Fira Code", monospace);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 0.75rem;
  }

  .collection-page__desc {
    font-family: var(--font-body, "JetBrains Mono", monospace);
    font-size: 0.9rem;
    color: var(--color-brand-fg-muted, #a09888);
    text-align: center;
    max-width: 600px;
    margin: 0 auto 3rem;
    line-height: 1.6;
  }

  .collection-page__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: 12px;
    overflow: hidden;
    background: #111;
    border: 1px solid #1a1a1a;
    transition: all 0.3s ease;
  }

  .product-card:hover {
    border-color: #2a2520;
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
  }

  .product-card__image {
    aspect-ratio: 1;
    overflow: hidden;
    background: #1a1a1a;
  }

  .product-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .product-card:hover .product-card__img {
    transform: scale(1.05);
  }

  .product-card__info {
    padding: 1.25rem;
  }

  .product-card__name {
    font-family: var(--font-heading, "Fira Code", monospace);
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .product-card__price {
    font-family: var(--font-body, "JetBrains Mono", monospace);
    font-size: 0.95rem;
    color: var(--color-brand-gold, #c9a84c);
    font-weight: 600;
  }

  .collection-page__pagination {
    grid-column: 1 / -1;
    text-align: center;
    padding-top: 2rem;
  }

  .collection-page__pagination a,
  .collection-page__pagination span {
    font-family: var(--font-body, "JetBrains Mono", monospace);
    font-size: 0.85rem;
    color: var(--color-brand-fg-muted, #a09888);
    text-decoration: none;
    padding: 8px 12px;
    border-radius: 6px;
    transition: all 0.2s ease;
  }

  .collection-page__pagination a:hover {
    color: var(--color-brand-gold, #c9a84c);
    background: rgba(201, 168, 76, 0.1);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.collection",
  "settings": []
}
{% endschema %}
