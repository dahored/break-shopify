{% comment %}
  FAQ Accordion Section
{% endcomment %}

<section class="product-faq full-width" id="faq">
  <div class="product-faq__container">
    {%- if section.settings.overline != blank -%}
      <span class="product-faq__overline">{{ section.settings.overline }}</span>
    {%- endif -%}

    <h2 class="product-faq__heading">{{ section.settings.heading }}</h2>

    <div class="product-faq__list">
      {%- for block in section.blocks -%}
        <details class="product-faq__item" {{ block.shopify_attributes }}>
          <summary class="product-faq__question">
            <span>{{ block.settings.question }}</span>
            <svg class="product-faq__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
          </summary>
          <div class="product-faq__answer">
            <p>{{ block.settings.answer }}</p>
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .product-faq {
    background-color: #111;
    color: #f5f0e8;
  }

  .product-faq__container {
    max-width: 800px;
    margin: 0 auto;
    padding: 5rem 2rem;
    text-align: center;
  }

  .product-faq__overline {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #c9a84c;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .product-faq__heading {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 3rem;
  }

  .product-faq__list {
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .product-faq__item {
    border-bottom: 1px solid #222;
  }

  .product-faq__item:first-child {
    border-top: 1px solid #222;
  }

  .product-faq__question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 0;
    cursor: pointer;
    font-size: 1rem;
    font-weight: 600;
    color: #f5f0e8;
    list-style: none;
    transition: color 0.2s ease;
  }

  .product-faq__question::-webkit-details-marker {
    display: none;
  }

  .product-faq__question:hover {
    color: #c9a84c;
  }

  .product-faq__chevron {
    transition: transform 0.3s ease;
    flex-shrink: 0;
    margin-left: 1rem;
    color: #666;
  }

  .product-faq__item[open] .product-faq__chevron {
    transform: rotate(180deg);
    color: #c9a84c;
  }

  .product-faq__answer {
    padding: 0 0 1.5rem;
    font-size: 0.925rem;
    line-height: 1.7;
    color: #a09888;
  }

  @media (max-width: 600px) {
    .product-faq__container {
      padding: 3rem 1.25rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Producto - FAQ",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Texto superior",
      "default": "Preguntas frecuentes"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "¿Tienes alguna duda?"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Pregunta",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Pregunta",
          "default": "¿Cuándo recibo mi bitácora?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Respuesta",
          "default": "Los envíos se realizan dentro de los 5 días hábiles posteriores a la compra. Recibirás un código de seguimiento por email."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Producto - FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "¿Cuándo recibo mi bitácora?",
            "answer": "Los envíos se realizan dentro de los 5 días hábiles posteriores a la compra. Recibirás un código de seguimiento por email."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "¿El envío es realmente gratis?",
            "answer": "Sí, el envío es completamente gratis a todo el país. Sin costos ocultos ni sorpresas."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "¿Puedo pagar en cuotas?",
            "answer": "¡Por supuesto! Ofrecemos hasta 3 cuotas sin interés con tarjetas de crédito."
          }
        },
        {
          "type": "faq",
