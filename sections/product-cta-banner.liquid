{% comment %}
  CTA Banner Section - Invitational buy banner with product image
  Single-product store: uses product picker or page product
{% endcomment %}

{%- assign p = section.settings.product | default: product -%}

<section class="cta-banner full-width" id="comprar-ahora">
  <div class="cta-banner__container">
    <div class="cta-banner__content">
      {%- if section.settings.overline != blank -%}
        <span class="cta-banner__overline">{{ section.settings.overline }}</span>
      {%- endif -%}

      <h2 class="cta-banner__heading">{{ section.settings.heading }}</h2>

      {%- if section.settings.subheading != blank -%}
        <p class="cta-banner__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="cta-banner__perks">
          {%- for block in section.blocks -%}
            <li class="cta-banner__perk" {{ block.shopify_attributes }}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              <span>{{ block.settings.text }}</span>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if p -%}
        {%- assign current_variant = p.selected_or_first_available_variant -%}

        {%- if section.settings.show_price and current_variant -%}
          <div class="cta-banner__price">
            {%- if current_variant.compare_at_price > current_variant.price -%}
              <span class="cta-banner__price-old">{{ current_variant.compare_at_price | money }}</span>
            {%- endif -%}
            <span class="cta-banner__price-now">{{ current_variant.price | money }}</span>
            {%- if section.settings.price_note != blank -%}
              <span class="cta-banner__price-note">{{ section.settings.price_note }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {% form 'product', p, class: 'cta-banner__form' %}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <button type="submit" class="cta-banner__btn" {% unless current_variant.available %}disabled{% endunless %}>
            {%- if current_variant.available -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
              {{ section.settings.button_text | default: 'Comprar ahora' }}
            {%- else -%}
              Agotado
            {%- endif -%}
          </button>
        {% endform %}
      {%- else -%}
        <a href="#" class="cta-banner__btn">{{ section.settings.button_text | default: 'Comprar ahora' }}</a>
      {%- endif -%}

      {%- if section.settings.footer_text != blank -%}
        <p class="cta-banner__footer">{{ section.settings.footer_text }}</p>
      {%- endif -%}
    </div>

    {%- if section.settings.image != blank -%}
      <div class="cta-banner__media">
        <img
          src="{{ section.settings.image | image_url: width: 600 }}"
          alt="{{ section.settings.image.alt | escape }}"
          class="cta-banner__image"
          loading="lazy"
        >
      </div>
    {%- elsif p.featured_image -%}
      <div class="cta-banner__media">
        <img
          src="{{ p.featured_image | image_url: width: 600 }}"
          alt="{{ p.featured_image.alt | escape }}"
          class="cta-banner__image"
          loading="lazy"
        >
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .cta-banner {
    background: linear-gradient(135deg, #111 0%, #0d0d0d 50%, #1a1510 100%);
    color: #f5f0e8;
    border-top: 1px solid #1a1a1a;
    border-bottom: 1px solid #1a1a1a;
  }

  .cta-banner__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  /* Content */
  .cta-banner__overline {
    display: inline-block;
    font-family: "Fira Code", monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #c9a84c;
    margin-bottom: 1rem;
  }

  .cta-banner__heading {
    font-family: "Fira Code", monospace;
    font-size: clamp(1.5rem, 3.5vw, 2.4rem);
    font-weight: 700;
    line-height: 1.2;
    color: #f5f0e8;
    margin-bottom: 1rem;
  }

  .cta-banner__subheading {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.9rem;
    line-height: 1.7;
    color: #a09888;
    margin-bottom: 2rem;
  }

  /* Perks list */
  .cta-banner__perks {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .cta-banner__perk {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.85rem;
    color: #d1c8b8;
  }

  .cta-banner__perk svg {
    flex-shrink: 0;
  }

  /* Price */
  .cta-banner__price {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .cta-banner__price-now {
    font-family: "Fira Code", monospace;
    font-size: 2rem;
    font-weight: 700;
    color: #c9a84c;
  }

  .cta-banner__price-old {
    font-family: "Fira Code", monospace;
    font-size: 1.1rem;
    color: #666;
    text-decoration: line-through;
  }

  .cta-banner__price-note {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    color: #a09888;
  }

  /* Button */
  .cta-banner__form {
    display: flex;
    flex-direction: column;
  }

  .cta-banner__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    padding: 1rem 2.5rem;
    background: #c9a84c;
    color: #0d0d0d;
    font-family: "Fira Code", monospace;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.25s ease;
    max-width: 360px;
  }

  .cta-banner__btn:hover {
    background: #d4b35a;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(201, 168, 76, 0.3);
  }

  .cta-banner__btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  /* Footer text */
  .cta-banner__footer {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    color: #555;
    margin-top: 1rem;
    font-style: italic;
  }

  /* Media */
  .cta-banner__media {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cta-banner__image {
    max-width: 100%;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
    transition: transform 0.5s ease;
  }

  .cta-banner__media:hover .cta-banner__image {
    transform: scale(1.02);
  }

  /* Mobile */
  @media (max-width: 768px) {
    .cta-banner__container {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 3.5rem 1.25rem;
      text-align: center;
    }

    .cta-banner__perks {
      align-items: center;
    }

    .cta-banner__price {
      justify-content: center;
    }

    .cta-banner__form {
      align-items: center;
    }

    .cta-banner__btn {
      width: 100%;
      max-width: none;
    }

    .cta-banner__footer {
      text-align: center;
    }

    .cta-banner__media {
      order: -1;
    }

    .cta-banner__image {
      max-width: 280px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "CTA - Banner Compra",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Producto"
    },
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Texto superior",
      "default": "No te quedes sin la tuya"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Título",
      "default": "Tu bitácora te está esperando"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subtítulo",
      "default": "Más de 200 páginas diseñadas para que documentes tu camino como programador. Edición limitada que no se reimprime."
    },
    {
      "type": "header",
      "content": "Precio"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Mostrar precio",
      "default": true
    },
    {
      "type": "text",
      "id": "price_note",
      "label": "Nota de precio",
      "default": "3 cuotas sin interés",
      "info": "Texto al lado del precio. Dejar vacío para ocultar."
    },
    {
      "type": "header",
      "content": "Botón"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón",
      "default": "Comprar ahora"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Texto debajo del botón",
      "default": "Envío gratis · Garantía de 7 días · Compra 100% segura",
      "info": "Dejar vacío para ocultar"
    },
    {
      "type": "header",
      "content": "Imagen"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen",
      "info": "Si no se sube imagen, usa la imagen principal del producto."
    }
  ],
  "blocks": [
    {
      "type": "perk",
      "name": "Beneficio",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Envío gratis a todo el país"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "CTA - Banner Compra",
      "blocks": [
        { "type": "perk", "settings": { "text": "Edición limitada con diseño premium" } },
        { "type": "perk", "settings": { "text": "Envío gratis a todo el país" } },
        { "type": "perk", "settings": { "text": "3 cuotas sin interés" } },
        { "type": "perk", "settings": { "text": "Bonos digitales incluidos" } }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
