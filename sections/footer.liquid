<footer class="footer full-width">
  <div class="footer__inner">
    <div class="footer__top">
      <div class="footer__brand" style="--footer-logo-max-w: {{ section.settings.logo_max_width | default: 140 }}px">
        {%- if section.settings.logo != blank -%}
          <a href="{{ routes.root_url }}">
            {% render 'image', image: section.settings.logo, class: 'footer__logo-img' %}
          </a>
        {%- else -%}
          <a href="{{ routes.root_url }}" class="footer__logo-text">{{ shop.name }}</a>
        {%- endif -%}

        {%- if section.settings.tagline != blank -%}
          <p class="footer__tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}

        {%- if section.settings.show_social -%}
          <div class="footer__social">
            {%- if section.settings.social_instagram != blank -%}
              <a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram" class="footer__social-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_twitter != blank -%}
              <a href="{{ section.settings.social_twitter }}" target="_blank" rel="noopener" aria-label="Twitter/X" class="footer__social-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4l11.733 16h4.267l-11.733-16z"/><path d="M4 20l6.768-6.768M20 4l-6.768 6.768"/></svg>
              </a>
            {%- endif -%}
            {%- if section.settings.social_tiktok != blank -%}
              <a href="{{ section.settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok" class="footer__social-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 12a4 4 0 104 4V4a5 5 0 005 5"/></svg>
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <div class="footer__links-group">
        {%- if section.settings.links_title != blank -%}
          <h4 class="footer__links-title">{{ section.settings.links_title }}</h4>
        {%- endif -%}
        <nav class="footer__links">
          {% for link in section.settings.menu.links %}
            <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
          {% endfor %}
        </nav>
      </div>
    </div>

    <div class="footer__bottom">
      <div class="footer__copyright">
        <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.</span>
        <span class="footer__rights">Todos los derechos reservados.</span>
      </div>

      <div class="footer__payment">
        {% if section.settings.show_payment_icons %}
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag }}
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer {
    background-color: #0a0a0a;
    color: #a09888;
    border-top: 1px solid #1a1a1a;
  }

  .footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 4rem 2rem 2rem;
  }

  /* Top section */
  .footer__top {
    display: flex;
    justify-content: space-between;
    gap: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid #1a1a1a;
  }

  .footer__brand {
    max-width: 320px;
  }

  .footer__logo-img {
    height: auto;
    width: auto;
    max-width: var(--footer-logo-max-w, 140px);
    max-height: 40px;
    margin-bottom: 1rem;
  }

  .footer__logo-text {
    font-family: "Fira Code", monospace;
    font-size: 1.1rem;
    font-weight: 700;
    color: #c9a84c;
    text-decoration: none;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 1rem;
  }

  .footer__tagline {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.825rem;
    line-height: 1.6;
    color: #666;
    margin-bottom: 1.25rem;
  }

  /* Social */
  .footer__social {
    display: flex;
    gap: 0.75rem;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid #222;
    color: #666;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .footer__social-link:hover {
    border-color: #c9a84c;
    color: #c9a84c;
    background: rgba(201, 168, 76, 0.05);
  }

  /* Links */
  .footer__links-group {
    min-width: 160px;
  }

  .footer__links-title {
    font-family: "Fira Code", monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: #f5f0e8;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__link {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8rem;
    color: #666;
    text-decoration: none;
    transition: color 0.2s ease;
    letter-spacing: 0.02em;
  }

  .footer__link:hover {
    color: #c9a84c;
  }

  /* Bottom */
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer__copyright {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    color: #444;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .footer__payment {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .footer__payment svg {
    height: 24px;
    width: auto;
    opacity: 0.4;
    transition: opacity 0.2s ease;
  }

  .footer__payment svg:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .footer__inner {
      padding: 3rem 1.25rem 1.5rem;
    }

    .footer__top {
      flex-direction: column;
      gap: 2.5rem;
      text-align: center;
    }

    .footer__brand {
      max-width: 100%;
    }

    .footer__social {
      justify-content: center;
    }

    .footer__links-group {
      min-width: unset;
    }

    .footer__links {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
    }

    .footer__links-title {
      text-align: center;
    }

    .footer__bottom {
      justify-content: center;
      text-align: center;
    }

    .footer__copyright {
      justify-content: center;
      width: 100%;
    }

    .footer__payment {
      justify-content: center;
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "range",
      "id": "logo_max_width",
      "label": "Ancho máximo del logo",
      "min": 60,
      "max": 240,
      "step": 10,
      "default": 140,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "La primera bitácora diseñada para programadores."
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "text",
      "id": "links_title",
      "label": "Título de links",
      "default": "Links"
    },
    {
      "type": "header",
      "content": "Redes sociales"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Mostrar redes sociales",
      "default": true
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "Twitter/X URL"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "header",
      "content": "Pagos"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ]
}
{% endschema %}
