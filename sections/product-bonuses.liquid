{% comment %}
  Bonuses/Extras Section - Cards showing bonus items included
{% endcomment %}

<section class="product-bonuses full-width" id="bonuses">
  <div class="product-bonuses__container">
    {%- if section.settings.overline != blank -%}
      <span class="product-bonuses__overline">{{ section.settings.overline }}</span>
    {%- endif -%}

    <h2 class="product-bonuses__heading">{{ section.settings.heading }}</h2>

    {%- if section.settings.subheading != blank -%}
      <p class="product-bonuses__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="product-bonuses__grid">
      {%- for block in section.blocks -%}
        <div class="product-bonuses__card" {{ block.shopify_attributes }}>
          <div class="product-bonuses__card-badge">{{ block.settings.badge | default: 'BONUS' }} #{{ forloop.index }}</div>
          {%- if block.settings.image != blank -%}
            <div class="product-bonuses__card-image">
              {% render 'image', image: block.settings.image, class: 'product-bonuses__img' %}
            </div>
          {%- else -%}
            <div class="product-bonuses__card-image product-bonuses__card-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#333" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            </div>
          {%- endif -%}
          <div class="product-bonuses__card-content">
            <h3 class="product-bonuses__card-title">{{ block.settings.title }}</h3>
            {%- if block.settings.description != blank -%}
              <p class="product-bonuses__card-desc">{{ block.settings.description }}</p>
            {%- endif -%}
            {%- if block.settings.value != blank -%}
              <span class="product-bonuses__card-value">Valor: {{ block.settings.value }}</span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .product-bonuses {
    background-color: #0d0d0d;
    color: #f5f0e8;
  }

  .product-bonuses__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 2rem;
    text-align: center;
  }

  .product-bonuses__overline {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #c9a84c;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .product-bonuses__heading {
    font-size: clamp(1.75rem, 3.5vw, 2.8rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .product-bonuses__subheading {
    font-size: 1rem;
    color: #a09888;
    max-width: 600px;
    margin: 0 auto 3rem;
    line-height: 1.6;
  }

  .product-bonuses__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .product-bonuses__card {
    background: linear-gradient(145deg, #161616, #111);
    border: 1px solid #1f1f1f;
    border-radius: 16px;
    overflow: hidden;
    text-align: left;
    transition: all 0.3s ease;
    position: relative;
  }

  .product-bonuses__card:hover {
    border-color: #2a2520;
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
  }

  .product-bonuses__card-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    padding: 4px 12px;
    background-color: #c9a84c;
    color: #0d0d0d;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    border-radius: 4px;
    z-index: 2;
  }

  .product-bonuses__card-image {
    width: 100%;
    aspect-ratio: 16/10;
    overflow: hidden;
    background: #1a1a1a;
  }

  .product-bonuses__card-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-bonuses__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .product-bonuses__card:hover .product-bonuses__img {
    transform: scale(1.05);
  }

  .product-bonuses__card-content {
    padding: 1.5rem;
  }

  .product-bonuses__card-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #f5f0e8;
  }

  .product-bonuses__card-desc {
    font-size: 0.85rem;
    line-height: 1.6;
    color: #777;
    margin-bottom: 0.75rem;
  }

  .product-bonuses__card-value {
    font-size: 0.75rem;
    color: #c9a84c;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  @media (max-width: 600px) {
    .product-bonuses__container {
      padding: 3rem 1.25rem;
    }

    .product-bonuses__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
