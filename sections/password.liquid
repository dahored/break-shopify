{% comment %}
  This section is used in the password template to render landing page shown
  when password protection is applied to a store.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/password
{% endcomment %}

<section class="password-page full-width">
  <div class="password-page__container">
    <h1 class="password-page__title">{{ 'password.title' | t }}</h1>

    {% if shop.password_message %}
      <p class="password-page__message">{{ shop.password_message }}</p>
    {% endif %}

    {% form 'storefront_password' %}
      {% if form.errors %}
        <div class="password-page__errors">
          {{ form.errors | default_errors }}
        </div>
      {% endif %}

      <div class="password-page__form">
        <label for="password-input" class="password-page__label">{{ 'password.password' | t }}</label>
        <div class="password-page__input-group">
          <input type="password" name="password" id="password-input" class="password-page__input" placeholder="Ingresa la contraseña">
          <button type="submit" class="password-page__submit">{{ 'password.enter' | t }}</button>
        </div>
      </div>
    {% endform %}
  </div>
</section>

{% stylesheet %}
  .password-page {
    background-color: var(--color-brand-bg, #0d0d0d);
    color: var(--color-brand-fg, #f5f0e8);
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .password-page__container {
    max-width: 500px;
    margin: 0 auto;
    padding: 3rem 2rem;
    text-align: center;
  }

  .password-page__title {
    font-family: var(--font-heading, "Fira Code", monospace);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .password-page__message {
    font-family: var(--font-body, "JetBrains Mono", monospace);
    font-size: 0.9rem;
    color: var(--color-brand-fg-muted, #a09888);
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }

  .password-page__errors {
    background: rgba(139, 0, 0, 0.15);
    border: 1px solid rgba(139, 0, 0, 0.3);
    border-radius: 8px;
    padding: 1rem;
    margin-bottom: 1.5rem;
    font-family: var(--font-body, "JetBrains Mono", monospace);
    font-size: 0.85rem;
    color: #ff6b6b;
  }

  .password-page__label {
    display: block;
    font-family: var(--font-body, "JetBrains Mono", monospace);
    font-size: 0.75rem;
    color: var(--color-brand-fg-muted, #a09888);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
    font-weight: 600;
  }

  .password-page__input-group {
    display: flex;
    gap: 0.75rem;
  }

  .password-page__input {
    flex: 1;
    padding: 14px 16px;
    background: #1a1a1a;
    border: 1px solid #333;
    color: var(--color-brand-fg, #f5f0e8);
    font-family: var(--font-body, "JetBrains Mono", monospace);
    font-size: 0.9rem;
    border-radius: 8px;
    transition: border-color 0.2s ease;
  }

  .password-page__input:focus {
    outline: none;
    border-color: var(--color-brand-gold, #c9a84c);
  }

  .password-page__submit {
    padding: 14px 24px;
    background-color: var(--color-brand-gold, #c9a84c);
    color: #0d0d0d;
    border: none;
    border-radius: 8px;
    font-family: var(--font-body, "JetBrains Mono", monospace);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
  }

  .password-page__submit:hover {
    background-color: var(--color-brand-gold-hover, #d4b35a);
  }

  @media (max-width: 500px) {
    .password-page__input-group {
      flex-direction: column;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.password",
  "settings": []
}
{% endschema %}
