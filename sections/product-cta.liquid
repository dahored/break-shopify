{% comment %}
  Final CTA Section - Recap + call to action
  Works on product pages and index (uses product picker)
{% endcomment %}

{%- assign p = section.settings.product | default: product -%}

<section class="product-cta full-width" id="comprar">
  <div class="product-cta__container">
    {%- if section.settings.overline != blank -%}
      <span class="product-cta__overline">{{ section.settings.overline }}</span>
    {%- endif -%}

    <h2 class="product-cta__heading">{{ section.settings.heading }}</h2>

    {%- if section.settings.subheading != blank -%}
      <p class="product-cta__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.settings.show_recap -%}
      <div class="product-cta__recap">
        {%- for block in section.blocks -%}
          <div class="product-cta__recap-item" {{ block.shopify_attributes }}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#c9a84c" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span>{{ block.settings.text }}</span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if p -%}
      {%- assign current_variant = p.selected_or_first_available_variant -%}

      {%- if section.settings.show_price and current_variant -%}
        <div class="product-cta__price-block">
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="product-cta__price-compare">{{ current_variant.compare_at_price | money }}</span>
          {%- endif -%}
          <span class="product-cta__price-current">{{ current_variant.price | money }}</span>
        </div>
      {%- endif -%}

      {% form 'product', p, class: 'product-cta__form' %}
        <input type="hidden" name="id" value="{{ current_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="product-cta__button" {% unless current_variant.available %}disabled{% endunless %}>
          {%- if current_variant.available -%}
            {{ section.settings.button_text | default: 'Quiero mi bitácora' }}
          {%- else -%}
            Agotado
          {%- endif -%}
        </button>
      {% endform %}
    {%- else -%}
      <p class="product-cta__no-product" style="color: #666; font-size: 0.8rem;">Selecciona un producto en el editor para activar el botón de compra.</p>
    {%- endif -%}

    {%- if section.settings.guarantee_text != blank -%}
      <p class="product-cta__guarantee">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        {{ section.settings.guarantee_text }}
      </p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .product-cta {
    background: radial-gradient(ellipse at center, #1a1510 0%, #0d0d0d 70%);
    color: #f5f0e8;
  }

  .product-cta__container {
    max-width: 700px;
    margin: 0 auto;
    padding: 5rem 2rem;
    text-align: center;
  }

  .product-cta__overline {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #c9a84c;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .product-cta__heading {
    font-size: clamp(1.75rem, 3.5vw, 2.8rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .product-cta__subheading {
    font-size: 1.05rem;
    color: #a09888;
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }

  .product-cta__recap {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
    text-align: left;
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
  }

  .product-cta__recap-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: #d1c8b8;
  }

  .product-cta__recap-item svg {
    flex-shrink: 0;
  }

  .product-cta__price-block {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .product-cta__price-current {
    font-size: 2.5rem;
    font-weight: 800;
    color: #f5f0e8;
  }

  .product-cta__price-compare {
    font-size: 1.5rem;
    text-decoration: line-through;
    color: #666;
  }

  .product-cta__form {
    width: 100%;
  }

  .product-cta__button {
    display: inline-block;
    padding: 20px 64px;
    background-color: #c9a84c;
    color: #0d0d0d;
    border: none;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    width: 100%;
    max-width: 400px;
  }

  .product-cta__button:hover {
    background-color: #d4b35a;
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(201, 168, 76, 0.3);
  }

  .product-cta__button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .product-cta__guarantee {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.5rem;
    font-size: 0.8rem;
    color: #666;
  }

  .product-cta__guarantee svg {
    color: #c9a84c;
  }

  @media (max-width: 600px) {
    .product-cta__container {
      padding: 3rem 1.25rem;
    }

    .product-cta__button {
      padding: 18px 32px;
    }
  }
{% endstylesheet %}

{% schema %}
