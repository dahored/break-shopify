{% comment %}
  Product Benefits Section - Grid of benefits with icons
{% endcomment %}

<section class="product-benefits full-width" id="beneficios">
  <div class="product-benefits__container">
    {%- if section.settings.overline != blank -%}
      <span class="product-benefits__overline">{{ section.settings.overline }}</span>
    {%- endif -%}

    <h2 class="product-benefits__heading">{{ section.settings.heading }}</h2>

    {%- if section.settings.subheading != blank -%}
      <p class="product-benefits__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="product-benefits__grid">
      {%- for block in section.blocks -%}
        <div class="product-benefits__card" {{ block.shopify_attributes }}>
          <div class="product-benefits__icon">
            {%- if block.settings.image != blank -%}
              {% render 'image', image: block.settings.image, class: 'product-benefits__icon-img' %}
            {%- else -%}
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            {%- endif -%}
          </div>
          <h3 class="product-benefits__card-title">{{ block.settings.title }}</h3>
          {%- if block.settings.description != blank -%}
            <p class="product-benefits__card-desc">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .product-benefits {
    background-color: #0d0d0d;
    color: #f5f0e8;
  }

  .product-benefits__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 2rem;
    text-align: center;
  }

  .product-benefits__overline {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #c9a84c;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .product-benefits__heading {
    font-size: clamp(1.75rem, 3.5vw, 2.8rem);
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .product-benefits__subheading {
    font-size: 1rem;
    color: #a09888;
    max-width: 600px;
    margin: 0 auto 3rem;
    line-height: 1.6;
  }

  .product-benefits__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .product-benefits__card {
    background: linear-gradient(145deg, #161616, #111);
    border: 1px solid #1f1f1f;
    border-radius: 16px;
    padding: 2.5rem 2rem;
    text-align: center;
    transition: all 0.3s ease;
  }

  .product-benefits__card:hover {
    border-color: #2a2520;
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
  }

  .product-benefits__icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
    background: rgba(201, 168, 76, 0.1);
    border-radius: 12px;
    color: #c9a84c;
  }

  .product-benefits__icon-img {
    width: 32px;
    height: 32px;
    object-fit: contain;
  }

  .product-benefits__card-title {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: #f5f0e8;
  }

  .product-benefits__card-desc {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #777;
  }

  @media (max-width: 900px) {
    .product-benefits__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .product-benefits__grid {
      grid-template-columns: 1fr;
    }

    .product-benefits__container {
      padding: 3rem 1.25rem;
    }
  }
{% endstylesheet %}

{% schema %}
