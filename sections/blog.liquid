{% comment %}
  This section is used in the blog template to render the blog page listing all
  articles within a blog.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/blog
{% endcomment %}

<section class="blog-page full-width">
  <div class="blog-page__container">
    <h1 class="blog-page__title">{{ blog.title }}</h1>

    <div class="blog-page__grid">
      {% paginate blog.articles by 6 %}
        {% for article in blog.articles %}
          <a href="{{ article.url }}" class="blog-card">
            {% if article.image %}
              <div class="blog-card__image">
                {{ article.image | image_url: width: 800 | image_tag: class: 'blog-card__img' }}
              </div>
            {% endif %}
            <div class="blog-card__content">
              <h2 class="blog-card__title">{{ article.title }}</h2>
              {% assign date = article.published_at | time_tag: format: 'date' %}
              <p class="blog-card__meta">{{ date }} &middot; {{ article.author }}</p>
              {% if article.excerpt != blank %}
                <p class="blog-card__excerpt">{{ article.excerpt | strip_html | truncatewords: 25 }}</p>
              {% endif %}
            </div>
          </a>
        {% endfor %}

        {%- if paginate.pages > 1 -%}
          <div class="blog-page__pagination">
            {{- paginate | default_pagination -}}
          </div>
        {%- endif -%}
      {% endpaginate %}
    </div>
  </div>
</section>

{% stylesheet %}
  .blog-page {
    background-color: var(--color-brand-bg, #0d0d0d);
    color: var(--color-brand-fg, #f5f0e8);
  }

  .blog-page__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  .blog-page__title {
    font-family: var(--font-heading, "Fira Code", monospace);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 3rem;
  }

  .blog-page__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: 12px;
    overflow: hidden;
    background: #111;
    border: 1px solid #1a1a1a;
    transition: all 0.3s ease;
  }

  .blog-card:hover {
    border-color: #2a2520;
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
  }

  .blog-card__image {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #1a1a1a;
  }

  .blog-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .blog-card:hover .blog-card__img {
    transform: scale(1.05);
  }

  .blog-card__content {
    padding: 1.5rem;
  }

  .blog-card__title {
    font-family: var(--font-heading, "Fira Code", monospace);
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .blog-card__meta {
    font-family: var(--font-body, "JetBrains Mono", monospace);
    font-size: 0.75rem;
    color: #555;
    margin-bottom: 0.75rem;
  }

  .blog-card__excerpt {
    font-family: var(--font-body, "JetBrains Mono", monospace);
    font-size: 0.8rem;
    color: var(--color-brand-fg-muted, #a09888);
    line-height: 1.6;
  }

  .blog-page__pagination {
    grid-column: 1 / -1;
    text-align: center;
    padding-top: 2rem;
  }

  .blog-page__pagination a,
  .blog-page__pagination span {
    font-family: var(--font-body, "JetBrains Mono", monospace);
    font-size: 0.85rem;
    color: var(--color-brand-fg-muted, #a09888);
    text-decoration: none;
    padding: 8px 12px;
  }

  .blog-page__pagination a:hover {
    color: var(--color-brand-gold, #c9a84c);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.blog",
  "settings": []
}
{% endschema %}
