[
  {
    "name": "theme_info",
    "theme_name": "Break Theme",
    "theme_version": "1.0.0",
    "theme_author": "Break Universe",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "Fuentes"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "Fuente de respaldo",
        "info": "El tema usa Fira Code (títulos) y JetBrains Mono (texto) por defecto vía Google Fonts."
      },
      {
        "type": "header",
        "content": "Tamaños"
      },
      {
        "type": "range",
        "id": "heading_scale",
        "label": "Escala de títulos",
        "min": 80,
        "max": 150,
        "step": 5,
        "default": 100,
        "unit": "%"
      },
      {
        "type": "range",
        "id": "body_scale",
        "label": "Escala de texto",
        "min": 80,
        "max": 130,
        "step": 5,
        "default": 100,
        "unit": "%"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "range",
        "id": "max_page_width",
        "label": "Ancho máximo de página",
        "min": 1000,
        "max": 1600,
        "step": 50,
        "default": 1200,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 60,
        "step": 2,
        "unit": "px",
        "label": "Margen lateral mínimo",
        "default": 20
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 16,
        "step": 2,
        "unit": "px",
        "label": "Radio de bordes (inputs/botones)",
        "default": 8
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "header",
        "content": "Colores principales"
      },
      {
        "type": "color",
        "id": "background_color",
        "default": "#0d0d0d",
        "label": "Fondo"
      },
      {
        "type": "color",
        "id": "background_color_alt",
        "default": "#111111",
        "label": "Fondo alternativo"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#f5f0e8",
        "label": "Texto principal"
      },
      {
        "type": "color",
        "id": "foreground_color_muted",
        "default": "#a09888",
        "label": "Texto secundario"
      },
      {
        "type": "header",
        "content": "Color de marca"
      },
      {
        "type": "color",
        "id": "brand_color",
        "default": "#c9a84c",
        "label": "Color de acento (dorado)"
      },
      {
        "type": "color",
        "id": "brand_color_hover",
        "default": "#d4b35a",
        "label": "Color de acento hover"
      }
    ]
  },
  {
    "name": "CSS personalizado",
    "settings": [
      {
        "type": "textarea",
        "id": "custom_css",
        "label": "CSS personalizado",
        "info": "Añade CSS personalizado que se aplicará a todo el tema."
      }
    ]
  }
]
