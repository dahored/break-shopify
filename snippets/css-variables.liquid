{% style %}
  {% # Loads all font variations with display: swap %}
  {{ settings.type_primary_font | font_face: font_display: 'swap' }}
  {{ settings.type_primary_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_primary_font | font_modify: 'weight', 'bold' | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}
  {{ settings.type_primary_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  :root {
    /* Fallback font from Shopify font picker */
    --font-primary--family: {{ settings.type_primary_font.family }}, {{ settings.type_primary_font.fallback_families }};
    --font-primary--style: {{ settings.type_primary_font.style }};
    --font-primary--weight: {{ settings.type_primary_font.weight }};

    /* Theme fonts (Google Fonts loaded in theme.liquid) */
    --font-heading: "Fira Code", monospace;
    --font-body: "JetBrains Mono", monospace;

    /* Font scale */
    --heading-scale: {{ settings.heading_scale | default: 100 | divided_by: 100.0 }};
    --body-scale: {{ settings.body_scale | default: 100 | divided_by: 100.0 }};

    /* Brand colors */
    --color-brand-gold: {{ settings.brand_color | default: '#c9a84c' }};
    --color-brand-gold-hover: {{ settings.brand_color_hover | default: '#d4b35a' }};

    /* Background */
    --color-brand-bg: {{ settings.background_color | default: '#0d0d0d' }};
    --color-brand-bg-alt: {{ settings.background_color_alt | default: '#111111' }};

    /* Foreground */
    --color-brand-fg: {{ settings.foreground_color | default: '#f5f0e8' }};
    --color-brand-fg-muted: {{ settings.foreground_color_muted | default: '#a09888' }};

    /* Layout */
    --page-width: {{ settings.max_page_width | default: 1200 }}px;
    --page-margin: {{ settings.min_page_margin | default: 20 }}px;

    /* Mapped aliases for compatibility */
    --color-background: {{ settings.background_color | default: '#0d0d0d' }};
    --color-foreground: {{ settings.foreground_color | default: '#f5f0e8' }};
    --style-border-radius-inputs: {{ settings.input_corner_radius | default: 8 }}px;
  }
{% endstyle %}

{%- if settings.custom_css != blank -%}
  <style>{{ settings.custom_css }}</style>
{%- endif -%}
